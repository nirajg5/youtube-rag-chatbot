{
  "manifest_version": 3,
  "name": "YouTube RAG Chatbot Extension",
  "version": "1.0.0",
  "description": "Automatically detects YouTube video IDs and enables RAG-powered chatbot interaction",
  "author": "Your Name",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "YouTube RAG Chatbot",
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://127.0.0.1:5000 http://localhost:5000"
  }
}